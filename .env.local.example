# ─── Supabase ────────────────────────────────────────────────────────
# Get these from: https://supabase.com → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Stripe ──────────────────────────────────────────────────────────
# Get these from: https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Stripe Price IDs ────────────────────────────────────────────────
# Create these in Stripe Dashboard → Products → Add Product
# Starter plan
STRIPE_STARTER_MONTHLY_PRICE_ID=price_...
STRIPE_STARTER_ANNUAL_PRICE_ID=price_...
# Professional plan
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_ANNUAL_PRICE_ID=price_...
# Enterprise plan
STRIPE_ENTERPRISE_MONTHLY_PRICE_ID=price_...
STRIPE_ENTERPRISE_ANNUAL_PRICE_ID=price_...

# ─── Anthropic AI ────────────────────────────────────────────────────
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ─── App ─────────────────────────────────────────────────────────────
# Your production URL (no trailing slash)
NEXT_PUBLIC_APP_URL=https://app.ziprohtraining.co.uk
